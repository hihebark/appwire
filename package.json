{
  "name": "appwire",
  "version": "0.1.0",
  "description": "Live app REPL for Node.js — run code inside your running app",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "appwire": "./dist/cli.cjs",
    "appwire-mcp": "./dist/mcp.cjs"
  },
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "prettier": "^3.8.4",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {}
}
