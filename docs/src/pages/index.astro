<script>
// ── Sticky nav radius ─────────────────────────────────────
(function() {
  const nav = document.querySelector('nav');
  if (!nav) return;
  const update = () => {
    const stuck = window.scrollY > 4;
    document.body.classList.toggle('nav-stuck', stuck);
  };
  window.addEventListener('scroll', update, { passive: true });
  update();
})();

// ── Hero interactive terminal ──────────────────────────────
(function() {
  const terminal = document.getElementById('hero-terminal');
  const body     = document.getElementById('hero-term-body');
  const inputEl  = document.getElementById('hero-term-input');
  if (!terminal) return;

  const MODE = 'ipc:main.ts';
  let cmdHistory = [], histIdx = -1, busy = false;

  const RESPONSES = [
    { re: /^\.timeit\s+\d+\s+/,         out: '[ { id: 1, email: \'alice@example.com\' }, { id: 2, email: \'bob@example.com\' }, ... ]\n  runs: 20  avg: 12ms  min: 9ms  max: 18ms', t: 'result' },
    { re: /^\.timeit/,                   out: '[ { id: 1, email: \'alice@example.com\' }, { id: 2, email: \'bob@example.com\' }, ... ]\n  time: 12ms',        t: 'result' },
    { re: /^\.doc/,                      out: '  UserService\n  Methods:\n    findAll()\n    findById(id)\n    create(dto)\n  Properties:\n    prisma', t: 'log' },
    { re: /^\.services/,                 out: '[ UserService, AuthService, OrderService, MailService ]',    t: 'log' },
    { re: /^\.help/,                     out: '.timeit  .doc  .services  .reload  .editor  .history  .clear  .exit', t: 'log' },
    { re: /^\.clear/,                    clear: true },
    { re: /\$app\.get\(UserService\)/,  out: 'UserService { repo: UserRepository, mailer: MailService }', t: 'result', ms: 1 },
    { re: /\$app\.get\(AuthService\)/,  out: 'AuthService { jwt: JwtService, users: UserService }',       t: 'result', ms: 1 },
    { re: /\$app\.get\(/,               out: '[ UserService, AuthService, OrderService, MailService ]',    t: 'result', ms: 2 },
    { re: /\$env\.DATABASE_URL/,        out: "'postgres://localhost/myapp'",                               t: 'string', ms: 0 },
    { re: /\$env\.NODE_ENV/,            out: "'development'",                                              t: 'string', ms: 0 },
    { re: /\$env/,                      out: "{ NODE_ENV: 'development', PORT: '3000', DATABASE_URL: '...' }", t: 'result', ms: 0 },
    { re: /await userService\.findOne/, out: "{ id: 42, name: 'Alice', email: 'alice@example.com' }",     t: 'result', ms: 12 },
    { re: /await userService\.findAll/, out: "[ { id: 1, name: 'Alice' }, { id: 2, name: 'Bob' }, ... ]", t: 'result', ms: 34 },
    { re: /await userService\.create/,  out: "{ id: 43, name: 'Bob', role: 'admin', createdAt: '...' }",  t: 'result', ms: 18 },
    { re: /\$db\.query/,                out: "[{ count: '1842' }]",                                        t: 'result', ms: 6 },
    { re: /\$db/,                       out: 'DataSource { isConnected: true, driver: PostgresDriver }',   t: 'result', ms: 0 },
    { re: /new Date\(\)/,               out: new Date().toISOString(),                                     t: 'result', ms: 0 },
    { re: /process\.version/,           out: "'v22.0.0'",                                                  t: 'string', ms: 0 },
    { re: /2\s*\+\s*2/,                out: '4',                                                           t: 'result', ms: 0 },
  ];

  function esc(s) {
    return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }

  function el(cls, html) {
    const d = document.createElement('div');
    d.className = cls; d.innerHTML = html; return d;
  }

  function scroll() { body.scrollTop = body.scrollHeight; }

  function newPrompt() {
    const p = el('terminal-line hero-current-prompt',
      `<span class="prompt">appwire<span class="prompt-mode">(${MODE})</span> &gt;</span>` +
      `<span class="code"> <span class="pt-text"></span><span class="cursor">█</span></span>`
    );
    body.appendChild(p); scroll(); return p;
  }

  function getResp(cmd) {
    const t = cmd.trim();
    if (!t) return null;
    for (const r of RESPONSES) if (r.re && r.re.test(t)) return r;
    if (t.startsWith('.')) return { out: `Unknown command: ${t.split(/\s/)[0]}`, t: 'error' };
    if (/^(const|let|var|function)\s/.test(t)) return { out: 'undefined', t: 'result', ms: 0 };
    if (/\bawait\b/.test(t)) return { out: '{ ... }', t: 'result', ms: Math.floor(Math.random() * 80) + 15 };
    return { out: 'undefined', t: 'result', ms: 0 };
  }

  const sleep = ms => new Promise(r => setTimeout(r, ms));

  async function runIntro() {
    // Type "$ appwire" character by character
    const cmdLine = el('terminal-line', '<span class="bash-prompt">$</span> <span class="bash-cmd"></span>');
    body.appendChild(cmdLine);
    const cmdSpan = cmdLine.querySelector('.bash-cmd');
    await sleep(500);
    for (const ch of 'appwire') {
      cmdSpan.textContent += ch;
      await sleep(130 + Math.random() * 70);
    }
    await sleep(350);

    // Startup lines
    const startupMsgs = [
      'appwire: detected entry src/main.ts (from package.json)',
      'appwire: using ts-node for TypeScript',
      'appwire: starting src/main.ts ...',
    ];
    for (const msg of startupMsgs) {
      body.appendChild(el('terminal-line output', `<span class="startup">${msg}</span>`));
      await sleep(220);
    }
    await sleep(250);
    body.appendChild(el('terminal-line spacer', ''));

    // Eval session
    body.appendChild(el('terminal-line',
      `<span class="prompt">appwire<span class="prompt-mode">(${MODE})</span> &gt;</span><span class="code"> $app.get(UserService)</span>`
    ));
    body.appendChild(el('terminal-line output',
      `<span class="result">UserService { repo: UserRepository }</span><span class="duration">1ms</span>`
    ));
    body.appendChild(el('terminal-line spacer', ''));
    prompt = newPrompt();
  }
  let prompt;
  runIntro();

  terminal.addEventListener('click', () => inputEl.focus());
  inputEl.addEventListener('focus', () => terminal.classList.add('is-focused'));
  inputEl.addEventListener('blur',  () => terminal.classList.remove('is-focused'));

  inputEl.addEventListener('input', () => {
    const pt = prompt.querySelector('.pt-text');
    if (pt) pt.textContent = inputEl.value;
  });

  inputEl.addEventListener('keydown', async (e) => {
    if (busy && e.key !== 'Tab') { e.preventDefault(); return; }

    if (e.key === 'Enter') {
      e.preventDefault();
      const cmd = inputEl.value; if (!cmd.trim()) return;
      cmdHistory.unshift(cmd); histIdx = -1;

      // Freeze prompt line
      prompt.innerHTML =
        `<span class="prompt">appwire<span class="prompt-mode">(${MODE})</span> &gt;</span><span class="code"> ${esc(cmd)}</span>`;
      prompt.classList.remove('hero-current-prompt');
      inputEl.value = '';

      const resp = getResp(cmd);
      if (!resp) { body.appendChild(el('terminal-line spacer','')); prompt = newPrompt(); return; }

      busy = true;
      await new Promise(r => setTimeout(r, Math.max(40, (resp.ms || 0) + 40)));

      if (resp.clear) {
        body.innerHTML = '';
      } else {
        const ms = resp.ms !== undefined ? `<span class="duration">${resp.ms}ms</span>` : '';
        const map = {
          result: `<span class="result">${esc(resp.out)}</span>${ms}`,
          string: `<span class="string">${esc(resp.out)}</span>${ms}`,
          log:    `<span class="log-line">${esc(resp.out)}</span>`,
          error:  `<span class="error-text">${esc(resp.out)}</span>`,
        };
        body.appendChild(el('terminal-line output', map[resp.t] || map.result));
        body.appendChild(el('terminal-line spacer', ''));
      }
      busy = false;
      prompt = newPrompt(); scroll();
    }

    if (e.key === 'ArrowUp') {
      e.preventDefault();
      if (histIdx < cmdHistory.length - 1) histIdx++;
      inputEl.value = cmdHistory[histIdx] || '';
      const pt = prompt.querySelector('.pt-text');
      if (pt) pt.textContent = inputEl.value;
    }

    if (e.key === 'ArrowDown') {
      e.preventDefault();
      histIdx = Math.max(-1, histIdx - 1);
      inputEl.value = histIdx >= 0 ? cmdHistory[histIdx] : '';
      const pt = prompt.querySelector('.pt-text');
      if (pt) pt.textContent = inputEl.value;
    }

    if (e.key === 'c' && e.ctrlKey) {
      prompt.innerHTML =
        `<span class="prompt">appwire<span class="prompt-mode">(${MODE})</span> &gt;</span>` +
        `<span class="code"> ${esc(inputEl.value)}</span><span class="muted" style="color:var(--muted)"> ^C</span>`;
      prompt.classList.remove('hero-current-prompt');
      inputEl.value = '';
      body.appendChild(el('terminal-line spacer', ''));
      prompt = newPrompt();
    }
  });

  document.querySelectorAll('.hint-chip').forEach(chip => {
    chip.addEventListener('click', (e) => {
      e.stopPropagation();
      if (busy) return;
      inputEl.value = chip.dataset.cmd;
      const pt = prompt.querySelector('.pt-text');
      if (pt) pt.textContent = chip.dataset.cmd;
      inputEl.focus();
    });
  });
})();
</script>

<script>
const P = (mode, code) =>
  `<div class="terminal-line"><span class="prompt">appwire<span class="prompt-mode">(${mode})</span> &gt;</span><span class="code"> ${code}</span></div>`;
const O = (text, ms) =>
  `<div class="terminal-line output"><span class="result">${text}</span>${ms !== undefined ? `<span class="duration">${ms}ms</span>` : ''}</div>`;
const S = (text, ms) =>
  `<div class="terminal-line output"><span class="string">${text}</span>${ms !== undefined ? `<span class="duration">${ms}ms</span>` : ''}</div>`;
const L = (text) =>
  `<div class="terminal-line output"><span class="log-line">${text}</span></div>`;
const SP = () => `<div class="terminal-line spacer"></div>`;
const C = (mode) =>
  `<div class="terminal-line"><span class="prompt">appwire<span class="prompt-mode">(${mode})</span> &gt;</span><span class="cursor">█</span></div>`;

const features = [
  {
    title: 'appwire · ipc:main.ts',
    html: [
      P('ipc:main.ts', '.services'),
      L('  UserService  AuthService  OrderService  MailService'),
      SP(),
      P('ipc:main.ts', '$app.get(OrderService)'),
      O('OrderService { db: DataSource, queue: BullQueue }', 1),
      SP(),
      C('ipc:main.ts'),
    ].join(''),
  },
  {
    title: 'appwire · ipc:main.ts',
    html: [
      P('ipc:main.ts', 'orderService.processOrder(99)'),
      L('[log] Fetching order #99...'),
      L('[log] Charging card ending 4242'),
      L('[log] Queuing confirmation email'),
      O("{ status: 'completed', total: 149.99 }", 230),
      SP(),
      C('ipc:main.ts'),
    ].join(''),
  },
  {
    title: 'appwire · ipc:main.ts',
    html: [
      P('ipc:main.ts', "const dto: CreateUserDto = { name: 'Bob', role: 'admin' }"),
      O('undefined', 0),
      SP(),
      P('ipc:main.ts', 'await userService.create(dto)'),
      O("{ id: 43, name: 'Bob', role: 'admin', createdAt: 2025-06-15 }", 18),
      SP(),
      C('ipc:main.ts'),
    ].join(''),
  },
  {
    title: 'appwire · ipc:main.ts',
    html: [
      P('ipc:main.ts', "await $db.query('SELECT count(*) FROM orders')"),
      O("[{ count: '8291' }]", 6),
      SP(),
      P('ipc:main.ts', '$env.DATABASE_URL'),
      S("'postgres://db.internal/prod'", 0),
      SP(),
      C('ipc:main.ts'),
    ].join(''),
  },
  {
    title: 'appwire · ipc:main.ts  [editor]',
    html: [
      P('ipc:main.ts', '.editor'),
      L('// Enter multi-line mode (^D to run, ^C to cancel)'),
      `<div class="terminal-line output"><span class="dim">...</span><span class="code"> const users = await userService.findAll()</span></div>`,
      `<div class="terminal-line output"><span class="dim">...</span><span class="code"> const admins = users.filter(u =&gt; u.role === 'admin')</span></div>`,
      `<div class="terminal-line output"><span class="dim">...</span><span class="code"> admins.map(u =&gt; u.email)</span></div>`,
      O("[ 'alice@example.com', 'carol@example.com' ]", 22),
      SP(),
      C('ipc:main.ts'),
    ].join(''),
  },
  {
    title: 'appwire · ipc:main.ts',
    html: [
      P('ipc:main.ts', 'BigInt(9007199254740993)'),
      O('9007199254740993n', 0),
      SP(),
      P('ipc:main.ts', "new Error('db timeout')"),
      `<div class="terminal-line output"><span class="error-text">Error: db timeout\n  at REPL:1:1\n  at eval (bootstrap:42:18)</span><span class="duration">0ms</span></div>`,
      SP(),
      C('ipc:main.ts'),
    ].join(''),
  },
];

const body = document.getElementById('more-terminal-body');
const titleEl = document.getElementById('more-terminal-title');

const items = Array.from(document.querySelectorAll('.more-item[data-feature]'));
let current = 0;
let animTimeouts = [];

function setFeature(idx, animate) {
  animTimeouts.forEach(clearTimeout);
  animTimeouts = [];
  const f = features[idx];
  body.innerHTML = f.html;
  titleEl.textContent = f.title;
  if (!animate) return;
  const lines = [...body.querySelectorAll('.terminal-line')];
  lines.forEach(line => { line.style.opacity = '0'; line.style.transform = 'translateY(5px)'; });
  let delay = 0;
  lines.forEach(line => {
    const d = delay;
    animTimeouts.push(setTimeout(() => {
      line.style.transition = 'opacity 0.22s ease, transform 0.22s ease';
      line.style.opacity = '1';
      line.style.transform = 'none';
    }, d));
    if (!line.classList.contains('spacer')) delay += 120;
  });
}

const DURATION = 6500;

let activatedAt = Date.now();
let remainingOnPause = DURATION;
let hovering = false;

function activate(i, animate) {
  items.forEach(el => el.classList.remove('active'));
  items[i].classList.add('active');
  current = i;
  activatedAt = Date.now();
  remainingOnPause = DURATION;
  setFeature(i, animate);
}

let autoTimer = null;
function scheduleAdvance(delay = DURATION) {
  clearTimeout(autoTimer);
  if (hovering) return;
  autoTimer = setTimeout(() => {
    activate((current + 1) % features.length, true);
    scheduleAdvance();
  }, delay);
}

const moreList = document.querySelector('.more-list');
moreList.addEventListener('mouseenter', () => {
  hovering = true;
  remainingOnPause = DURATION - (Date.now() - activatedAt);
  clearTimeout(autoTimer);
});
moreList.addEventListener('mouseleave', () => {
  hovering = false;
  activatedAt = Date.now() - (DURATION - remainingOnPause);
  scheduleAdvance(Math.max(200, remainingOnPause));
});

items.forEach((el, i) => {
  el.addEventListener('click', () => {
    if (i === current) return;
    activate(i, true);
    scheduleAdvance();
  });
});

activate(0, false);
scheduleAdvance();

// ── Scroll reveal ──────────────────────────────────────────
(function() {
  const groups = [
    ['.features h2'],
    ['.features .feat-cell'],
    ['.more h2', '.more-sub'],
    ['.more-list', '.more-terminal-wrap'],
    ['.modes h2'],
    ['.mode-card'],
    ['.cta h2', '.cta-row'],
  ];

  groups.forEach((selectors, gi) => {
    selectors.forEach((sel, si) => {
      document.querySelectorAll(sel).forEach((el, ei) => {
        el.classList.add('reveal');
        el.style.transitionDelay = `${(gi * 0 + si * 80 + ei * 80)}ms`;
      });
    });
  });

  const io = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.classList.add('visible');
        io.unobserve(e.target);
      }
    });
  }, { threshold: 0.08, rootMargin: '0px 0px -30px 0px' });

  document.querySelectorAll('.reveal').forEach(el => io.observe(el));
})();

</script>

<script>
document.querySelectorAll('.faq-q').forEach(btn => {
  btn.addEventListener('click', () => {
    btn.closest('.faq-item').classList.toggle('open');
  });
});
</script>

</body>
</html>
