<div class="page-wrap">
  <!-- Hero -->
  <section class="hero">
    <div class="hero-inner">

      <div class="hero-left">
        <h1>Inspect your running app.</h1>

        <p class="hero-sub">
          Run code inside your live app. <code>$app.get(UserService)</code> returns the real instance.
        </p>

        <div class="hero-install">
          <span class="hero-install-prompt">$</span>
          <span class="hero-install-cmd">npm install -g appwire</span>
        </div>
      </div>

      <div class="hero-right">
        <div class="terminal hero-terminal" id="hero-terminal">
          <div class="terminal-bar">
            <span class="dot red"></span>
            <span class="dot yellow"></span>
            <span class="dot green"></span>
            <span class="terminal-title">appwire · ipc:main.ts</span>
          </div>
          <div class="terminal-body" id="hero-term-body"></div>
          <input id="hero-term-input" type="text" autocomplete="off" autocorrect="off" autocapitalize="none" spellcheck="false" aria-label="REPL input" />
        </div>
        <div class="hero-term-hint">
          <span class="hint-label">try:</span>
          <button class="hint-chip" data-cmd="$app.get(UserService)">$app.get(UserService)</button>
          <button class="hint-chip" data-cmd="$env.DATABASE_URL">$env.DATABASE_URL</button>
          <button class="hint-chip" data-cmd=".timeit 20 $app.get(UserService).findAll()">.timeit</button>
          <button class="hint-chip" data-cmd=".services">.services</button>
        </div>
      </div>

    </div>
    <div class="scroll-hint" aria-hidden="true">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>
    </div>
  </section>

